#!/bin/sh
set -e

npm run build

if ! git diff --quiet -- docs; then
  printf '%s\n' 'docs changed after npm run build. Commit the updated build artifacts before pushing.' >&2
  exit 1
fi

if [ -n "$(git ls-files --others --exclude-standard docs)" ]; then
  printf '%s\n' 'docs contains untracked build artifacts. Add and commit them before pushing.' >&2
  exit 1
fi
